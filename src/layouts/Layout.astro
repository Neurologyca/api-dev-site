---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Developer Hub',
	description = 'A curated index of SDKs, APIs, docs, and tools for developers.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#101827" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Newsreader:opsz,wght@6..72,500;6..72,700&display=swap"
			rel="stylesheet"
		/>
		<link rel="icon" type="image/svg+xml" href="./favicon.svg" />
		<link rel="icon" href="./favicon.ico" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--bg: #101827;
		--bg-elevated: rgba(17, 24, 39, 0.78);
		--bg-panel: rgba(30, 41, 59, 0.58);
		--bg-panel-strong: rgba(15, 23, 42, 0.88);
		--line: rgba(148, 163, 184, 0.18);
		--line-strong: rgba(148, 163, 184, 0.28);
		--text: #e5eefc;
		--muted: #a7b7d6;
		--soft: #7f93b8;
		--accent: #160a68;
		--accent-bright: #2f1bad;
		--accent-soft: rgba(22, 10, 104, 0.22);
		--logo-blue: #3095ff;
		--shadow: 0 30px 80px rgba(2, 6, 23, 0.42);
		--radius-lg: 28px;
		--radius-md: 20px;
		--radius-sm: 14px;
		--max-width: 1180px;
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-width: 320px;
		color: var(--text);
		font-family: 'Manrope', sans-serif;
		background:
			radial-gradient(circle at top left, rgba(48, 149, 255, 0.12), transparent 24%),
			radial-gradient(circle at 80% 0%, rgba(22, 10, 104, 0.34), transparent 28%),
			linear-gradient(180deg, #0c1422 0%, #101827 38%, #0b1220 100%);
	}

	body::before {
		content: '';
		position: fixed;
		inset: 0;
		pointer-events: none;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
		background-size: 36px 36px;
		mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.34), transparent 85%);
		opacity: 0.18;
	}

	main {
		position: relative;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	img {
		display: block;
		max-width: 100%;
	}

	.container {
		width: min(calc(100% - 2rem), var(--max-width));
		margin: 0 auto;
	}

	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		padding: 0.55rem 0.9rem;
		border: 1px solid var(--line);
		border-radius: 999px;
		background: rgba(15, 23, 42, 0.5);
		color: var(--muted);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.eyebrow::before {
		content: '';
		width: 0.55rem;
		height: 0.55rem;
		border-radius: 999px;
		background: linear-gradient(180deg, var(--logo-blue), var(--accent-bright));
		box-shadow: 0 0 18px rgba(48, 149, 255, 0.45);
	}

	.section-title {
		margin: 0;
		font-family: 'Newsreader', serif;
		font-size: clamp(2rem, 3vw, 3rem);
		font-weight: 700;
		letter-spacing: -0.04em;
	}

	.section-copy {
		margin: 0;
		max-width: 46rem;
		color: var(--muted);
		font-size: 1rem;
		line-height: 1.75;
	}
	
	@media (max-width: 720px) {
		.container {
			width: min(calc(100% - 1.2rem), var(--max-width));
		}
	}
</style>
