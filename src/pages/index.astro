---
import Layout from '../layouts/Layout.astro';
import resources from '../data/resources.json';

const { site, sections } = resources;
const baseUrl = import.meta.env.BASE_URL;
---

<Layout title={site.name} description={site.description}>
	<main>
		<header class="site-header">
			<div class="container header-inner">
				<a class="brand" href="#" aria-label={`${site.name} home`}>
					<img src={`${baseUrl}branding/logo.svg`} alt={`${site.name} logo`} />
				</a>
				<nav class="header-nav" aria-label="Section navigation">
					{sections.map((section) => <a href={`#${section.id}`}>{section.title}</a>)}
				</nav>
			</div>
		</header>

		<section class="hero" id="top">
			<div class="container">
				<div class="hero-copy">
					<h1>{site.headline}</h1>
					<p>{site.description}</p>
				</div>
			</div>
		</section>

		{
			sections.map((section) => (
				<section class="resource-section" id={section.id}>
					<div class="container">
						<div class="section-heading">
							<div>
								<h2 class="section-title">{section.title}</h2>
							</div>
							<p class="section-copy">{section.description}</p>
						</div>

						<div class="resource-grid">
							{section.items.map((item) => (
								<a
									class:list={['resource-card', { 'resource-card-disabled': item.disabled }]}
									href={item.disabled ? undefined : item.url}
									target={item.disabled ? undefined : '_blank'}
									rel={item.disabled ? undefined : 'noreferrer'}
									aria-disabled={item.disabled ? 'true' : undefined}
								>
									<span class="resource-type">{item.type}</span>
									<h3>{item.title}</h3>
									<p>{item.description}</p>
									{
										item.details && (
											<div class="resource-details">
												{item.details.map((detail) => (
													<div class="detail-row">
														<span>{detail.label}</span>
														<code>{detail.value}</code>
													</div>
												))}
											</div>
										)
									}
								</a>
							))}
						</div>
					</div>
				</section>
			))
		}

		<footer class="site-footer">
			<div class="container footer-inner">
				<p>{site.name}</p>
			</div>
		</footer>
	</main>
</Layout>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		backdrop-filter: blur(22px);
		background: rgba(12, 20, 34, 0.72);
		border-bottom: 1px solid rgba(148, 163, 184, 0.08);
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		padding: 1rem 0;
	}

	.brand {
		display: inline-flex;
		align-items: center;
	}

	.brand img {
		height: auto;
		width: clamp(168px, 22vw, 220px);
	}

	.header-nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.6rem;
	}

	.header-nav a {
		padding: 0.7rem 0.95rem;
		border-radius: 999px;
		color: var(--muted);
		font-size: 0.92rem;
		font-weight: 700;
		transition:
			color 180ms ease,
			background 180ms ease,
			transform 180ms ease;
	}

	.header-nav a:hover,
	.header-nav a:focus-visible {
		background: rgba(255, 255, 255, 0.05);
		color: var(--text);
		transform: translateY(-1px);
	}

	.hero {
		padding: 5.5rem 0 2.25rem;
	}

	.hero-copy,
	.resource-card {
		border: 1px solid var(--line);
		box-shadow: var(--shadow);
	}

	.hero-copy {
		padding: clamp(2rem, 4vw, 4rem);
		border-radius: var(--radius-lg);
		background:
			linear-gradient(135deg, rgba(48, 149, 255, 0.08), transparent 32%),
			linear-gradient(160deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01)),
			var(--bg-elevated);
	}

	.hero-copy h1 {
		margin: 1.2rem 0 1rem;
		max-width: 18ch;
		font-family: 'Newsreader', serif;
		font-size: clamp(2.9rem, 6vw, 4.8rem);
		font-weight: 700;
		line-height: 0.98;
		letter-spacing: -0.055em;
	}

	.hero-copy p {
		margin: 0;
		max-width: 42rem;
		color: var(--muted);
		font-size: clamp(1rem, 1.9vw, 1.16rem);
		line-height: 1.9;
	}

	.resource-card:hover,
	.resource-card:focus-visible {
		transform: translateY(-2px);
	}

	.resource-section {
		padding: 1rem 0 3.4rem;
		scroll-margin-top: 6.5rem;
	}

	.section-heading {
		display: flex;
		justify-content: space-between;
		gap: 1.5rem;
		align-items: end;
		margin-bottom: 1.6rem;
	}

	.resource-card {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding: 1.4rem;
		border-radius: var(--radius-md);
		background:
			linear-gradient(180deg, rgba(48, 149, 255, 0.07), transparent 30%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.015)),
			var(--bg-panel);
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			background 180ms ease;
	}

	.resource-card:hover,
	.resource-card:focus-visible {
		border-color: rgba(128, 150, 255, 0.28);
		background:
			linear-gradient(180deg, rgba(48, 149, 255, 0.1), transparent 32%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02)),
			var(--bg-panel);
	}

	.resource-card h3 {
		margin: 0;
		font-size: 1.28rem;
		line-height: 1.25;
		letter-spacing: -0.03em;
	}

	.resource-card p {
		margin: 0;
		color: var(--muted);
		line-height: 1.8;
	}

	.resource-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.resource-details {
		display: grid;
		gap: 0.7rem;
		padding-top: 0.15rem;
		margin-top: auto;
		border-top: 1px solid rgba(148, 163, 184, 0.14);
	}

	.detail-row {
		display: grid;
		gap: 0.35rem;
	}

	.detail-row span {
		color: var(--soft);
		font-size: 0.74rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.detail-row code {
		display: inline-block;
		width: fit-content;
		padding: 0.45rem 0.6rem;
		border: 1px solid rgba(148, 163, 184, 0.2);
		border-radius: 0.7rem;
		background: rgba(15, 23, 42, 0.82);
		color: #edf3ff;
		font-size: 0.87rem;
		word-break: break-all;
	}

	.resource-type {
		font-size: 0.84rem;
		font-weight: 800;
		letter-spacing: 0.04em;
	}

	.resource-type {
		width: fit-content;
		padding: 0.45rem 0.7rem;
		border-radius: 999px;
		background: var(--accent-soft);
		color: #d6d0ff;
	}

	.resource-card-disabled {
		cursor: default;
		opacity: 0.78;
	}

	.resource-card-disabled:hover,
	.resource-card-disabled:focus-visible {
		transform: none;
		border-color: var(--line);
		background:
			linear-gradient(180deg, rgba(48, 149, 255, 0.07), transparent 30%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.015)),
			var(--bg-panel);
	}

	.site-footer {
		padding: 1rem 0 2.5rem;
	}

	.footer-inner {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		padding-top: 1.4rem;
		border-top: 1px solid var(--line);
		color: var(--soft);
		font-size: 0.95rem;
	}

	.footer-inner p {
		margin: 0;
	}

	@media (max-width: 980px) {
		.resource-grid,
		.section-heading,
		.footer-inner {
			grid-template-columns: 1fr;
			flex-direction: column;
		}

		.header-inner {
			flex-direction: column;
			align-items: flex-start;
		}

		.header-nav {
			justify-content: flex-start;
		}
	}

	@media (max-width: 720px) {
		.hero {
			padding-top: 3.5rem;
		}

		.hero-copy,
		.resource-card {
			padding: 1.25rem;
		}

		.hero-copy h1 {
			max-width: none;
		}
	}
</style>
